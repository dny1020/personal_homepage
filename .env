EXPERIENCE='[ { "title": "Telephony Engineer", "company": "EMTELCO S.A.", "period": "Jun 2024 - Present", "description": "Design and implement enterprise SIP telephony solutions. Build WebRTC contact center platforms with Asterisk and Kamailio. Automate VoIP provisioning and monitoring with Python, Bash, and Docker. Manage Linux infrastructure, Nginx reverse proxies, and CI/CD pipelines." }, { "title": "Telephony Analyst", "company": "EMTELCO S.A.", "period": "Oct 2021 - Jun 2024", "description": "Analyzed and optimized telephony infrastructure. Developed Python-based automation tools for Asterisk AMI/ARI. Implemented Prometheus and Grafana dashboards for real-time VoIP monitoring. Managed SBC configurations and Genesys Cloud BYOC integrations." }, { "title": "Help Desk Analyst", "company": "EMTELCO S.A.", "period": "Apr 2020 - Oct 2021", "description": "Provided technical support for telephony systems and network infrastructure. Resolved escalated tickets for SIP, VoIP, and network issues. Documented processes and contributed to knowledge base development." }, { "title": "Back Office Employee", "company": "Vodafone (via Teleperformance)", "period": "Jan 2019 - Dec 2019", "description": "Remote technical support for Vodafone customers. Router configuration, troubleshooting connectivity issues, and Linux system optimization for network services." }, { "title": "Help Desk Specialist", "company": "Claro Colombia (via Atento)", "period": "Feb 2012 - Nov 2018", "description": "6+ years providing specialized remote support for Claro Hogar. Fixed IP configuration, DMZ and NAT setups, network optimization, and customer troubleshooting for broadband and telephony services." } ]'

